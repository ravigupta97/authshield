# ================================================================
# AuthShield Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ================================================================

# ── Application ─────────────────────────────────────────────────
APP_NAME=AuthShield
APP_VERSION=1.0.0
APP_ENV=development           # development | staging | production
DEBUG=true

# ── Server ──────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database (PostgreSQL) ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://authshield_user:yourpassword@localhost:5432/authshield_db

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-256-bit-hex-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────────
# JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Email ───────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp            # smtp | sendgrid

# Option A: SMTP / Mailtrap (use for development)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=your_mailtrap_username
SMTP_PASSWORD=your_mailtrap_password
SMTP_USE_TLS=true
EMAIL_FROM=noreply@authshield.dev
EMAIL_FROM_NAME=AuthShield

# Option B: SendGrid (use for production)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# ── Frontend URLs (used inside email links) ─────────────────────
FRONTEND_URL=http://localhost:3000
VERIFY_EMAIL_PATH=/verify-email
RESET_PASSWORD_PATH=/reset-password

# ── Google OAuth ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# ── GitHub OAuth ────────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/github/callback

# ── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_REGISTER_PER_MINUTE=3
RATE_LIMIT_PASSWORD_RESET_PER_HOUR=3

# ── Password Policy ─────────────────────────────────────────────
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128

# ── 2FA ─────────────────────────────────────────────────────────
TOTP_ISSUER_NAME=AuthShield