# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.spec

# ── Virtual environments ──────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Testing ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
tests/
conftest.py
pytest.ini

# ── Secrets — NEVER bake these into the image ──────────────────────
.env
*.pem
*.key
*.crt
qrcode.png

# ── Version control ───────────────────────────────────────────────
.git/
.gitignore

# ── Editor / OS ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docs (not needed at runtime) ─────────────────────────────────
README.md
INTEGRATION_GUIDE.md
*.md
